{
  "key": "VIRTUAL_CACHE",
  "alias": "Virtual Cache",
  "group": "Virtual targets",
  "color": "var(--sw-warn)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/service-agent/virtual-cache/",
  "aliases": {
    "services": "Caches"
  },
  "components": {
    "service": true,
    "instances": false,
    "endpoints": false,
    "endpointDependency": false,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "cpm",
    "columns": [
      {
        "metric": "cpm",
        "label": "Access RPM",
        "unit": "rpm",
        "mqe": "cache_access_cpm",
        "aggregation": "sum"
      },
      {
        "metric": "respTime",
        "label": "Latency",
        "unit": "ms",
        "mqe": "cache_access_resp_time",
        "aggregation": "avg"
      },
      {
        "metric": "p95",
        "label": "p95",
        "unit": "ms",
        "mqe": "cache_access_percentile{p='95'}",
        "aggregation": "avg"
      },
      {
        "metric": "err",
        "label": "Error Rate",
        "unit": "%",
        "mqe": "100 - cache_access_sla/100",
        "aggregation": "avg"
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "access_cpm_line",
        "title": "Access Traffic",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "cache_access_cpm"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "access_resp_line",
        "title": "Avg Access Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "cache_access_resp_time"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "access_sla_line",
        "title": "Access Success Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "cache_access_sla/100"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "access_percentile",
        "title": "Access Latency Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(cache_access_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 12,
        "rowSpan": 2
      },
      {
        "id": "read_traffic",
        "title": "Read Traffic",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "cache_read_cpm"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "read_resp",
        "title": "Read Avg Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "cache_read_resp_time"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "write_traffic",
        "title": "Write Traffic",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "cache_write_cpm"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "write_resp",
        "title": "Write Avg Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "cache_write_resp_time"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "read_sla",
        "title": "Read Success Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "cache_read_sla/100"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "write_sla",
        "title": "Write Success Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "cache_write_sla/100"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "read_percentile",
        "title": "Read Latency Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(cache_read_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "write_percentile",
        "title": "Write Latency Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(cache_write_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "slow_read",
        "title": "Slow Read Commands",
        "tip": "Top 10 slowest captured read commands. Each row is a single execution \u2014 click to drill into the originating trace.",
        "type": "record",
        "unit": "ms",
        "expressions": [
          "top_n(top_n_cache_read_command, 10, des)"
        ],
        "span": 6,
        "rowSpan": 4
      },
      {
        "id": "slow_write",
        "title": "Slow Write Commands",
        "tip": "Top 10 slowest captured write commands. Each row is a single execution \u2014 click to drill into the originating trace.",
        "type": "record",
        "unit": "ms",
        "expressions": [
          "top_n(top_n_cache_write_command, 10, des)"
        ],
        "span": 6,
        "rowSpan": 4
      }
    ]
  }
}
