{
  "key": "ELASTICSEARCH",
  "alias": "Elasticsearch",
  "group": "Databases",
  "color": "var(--sw-cyan)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-elasticsearch-monitoring/",
  "aliases": {
    "services": "ES clusters",
    "instances": "Nodes",
    "endpoints": "Indices"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": true,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "shards",
    "columns": [
      {
        "metric": "health",
        "label": "Health",
        "mqe": "meter_elasticsearch_cluster_health_status",
        "aggregation": "avg"
      },
      {
        "metric": "shards",
        "label": "Shards",
        "mqe": "latest(meter_elasticsearch_cluster_shards_total)",
        "aggregation": "sum"
      },
      {
        "metric": "nodes",
        "label": "Nodes",
        "mqe": "latest(meter_elasticsearch_cluster_nodes)",
        "aggregation": "sum"
      },
      {
        "metric": "unassigned",
        "label": "Unassigned",
        "mqe": "latest(meter_elasticsearch_cluster_unassigned_shards_total)",
        "aggregation": "sum"
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "health",
        "title": "Cluster Health",
        "type": "table",
        "expressions": [
          "latest(meter_elasticsearch_cluster_health_status)"
        ],
        "span": 4,
        "rowSpan": 3,
        "tableHeaders": [
          "Status",
          "Value"
        ],
        "showTableValues": true
      },
      {
        "id": "nodes",
        "title": "Nodes",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_nodes)"
        ],
        "span": 3,
        "rowSpan": 1
      },
      {
        "id": "pending_tasks",
        "title": "Pending Tasks",
        "type": "card",
        "expressions": [
          "avg(meter_elasticsearch_cluster_pending_tasks_total)"
        ],
        "span": 3,
        "rowSpan": 1
      },
      {
        "id": "primary_shards",
        "title": "Primary Shards",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_primary_shards_total)"
        ],
        "span": 3,
        "rowSpan": 1
      },
      {
        "id": "shards_active",
        "title": "Active Shards",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_shards_total)"
        ],
        "span": 2,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "shards_initializing",
        "title": "Initializing",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_initializing_shards_total)"
        ],
        "span": 2,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "shards_relocating",
        "title": "Relocating",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_relocating_shards_total)"
        ],
        "span": 2,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "shards_unassigned",
        "title": "Unassigned",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_unassigned_shards_total)"
        ],
        "span": 2,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "shards_delayed",
        "title": "Delayed Unassigned",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_delayed_unassigned_shards_total)"
        ],
        "span": 2,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "breakers",
        "title": "Tripped Breakers",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_cluster_breakers_tripped)"
        ],
        "span": 3,
        "rowSpan": 1
      },
      {
        "id": "cluster_cpu",
        "title": "Cluster CPU Avg",
        "type": "card",
        "unit": "%",
        "expressions": [
          "avg(meter_elasticsearch_cluster_cpu_usage_avg)"
        ],
        "span": 3,
        "rowSpan": 1
      },
      {
        "id": "cluster_jvm",
        "title": "JVM Memory Used Avg",
        "type": "card",
        "expressions": [
          "avg(meter_elasticsearch_cluster_jvm_memory_used_avg)"
        ],
        "span": 4,
        "rowSpan": 1
      },
      {
        "id": "open_files",
        "title": "Open Files Avg",
        "type": "card",
        "expressions": [
          "avg(meter_elasticsearch_cluster_open_file_count)"
        ],
        "span": 4,
        "rowSpan": 1
      }
    ],
    "instance": [
      {
        "id": "cpu",
        "title": "Process CPU (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "meter_elasticsearch_node_process_cpu_percent"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "os_cpu",
        "title": "OS CPU (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "meter_elasticsearch_node_os_cpu_percent"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "load_avg",
        "title": "Load Average",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_os_load1",
          "meter_elasticsearch_node_os_load5",
          "meter_elasticsearch_node_os_load15"
        ],
        "expressionLabels": [
          "1m",
          "5m",
          "15m"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "jvm_mem",
        "title": "JVM Memory (MB)",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_jvm_memory_heap_used/1024/1024",
          "meter_elasticsearch_node_jvm_memory_heap_max/1024/1024",
          "meter_elasticsearch_node_jvm_memory_nonheap_used/1024/1024"
        ],
        "expressionLabels": [
          "heap used",
          "heap max",
          "non-heap"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "gc",
        "title": "GC",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_jvm_gc_count",
          "meter_elasticsearch_node_jvm_gc_time"
        ],
        "expressionLabels": [
          "count",
          "time (ms/min)"
        ],
        "expressionAxes": [
          0,
          1
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "translog",
        "title": "Translog",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_indices_translog_operations",
          "meter_elasticsearch_node_indices_translog_size/1024/1024"
        ],
        "expressionLabels": [
          "operations",
          "size (MB)"
        ],
        "expressionAxes": [
          0,
          1
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "breakers",
        "title": "Breakers",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_breakers_tripped",
          "meter_elasticsearch_node_breakers_estimated_size/1024/1024"
        ],
        "expressionLabels": [
          "tripped",
          "estimated (MB)"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "segments",
        "title": "Segments",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_segment_count",
          "meter_elasticsearch_node_segment_memory"
        ],
        "expressionLabels": [
          "count",
          "memory (MB)"
        ],
        "expressionAxes": [
          0,
          1
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "disk",
        "title": "Disk Usage",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_disk_usage/1024/1024/1024",
          "meter_elasticsearch_node_disk_usage_percent"
        ],
        "expressionLabels": [
          "GB",
          "%"
        ],
        "expressionAxes": [
          0,
          1
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "network",
        "title": "Network",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_node_network_send_bytes",
          "meter_elasticsearch_node_network_receive_bytes"
        ],
        "expressionLabels": [
          "send",
          "receive"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "open_files",
        "title": "Open Files",
        "type": "card",
        "expressions": [
          "avg(meter_elasticsearch_node_open_file_count)"
        ],
        "span": 6,
        "rowSpan": 1
      }
    ],
    "endpoint": [
      {
        "id": "indexing_rate",
        "title": "Indexing Rate",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_index_stats_indexing_index_total_req_rate",
          "meter_elasticsearch_index_stats_indexing_index_total_proc_rate"
        ],
        "expressionLabels": [
          "req",
          "proc"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "search_rate",
        "title": "Search Rate",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_index_stats_search_query_total_req_rate",
          "meter_elasticsearch_index_stats_search_query_total_proc_rate"
        ],
        "expressionLabels": [
          "req",
          "proc"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "idx_size_all",
        "title": "Index Size (all shards)",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_index_indices_store_size_bytes_total)/1024/1024/1024"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "decimal",
        "unit": "GB"
      },
      {
        "id": "idx_size_primary",
        "title": "Index Size (primary)",
        "type": "card",
        "expressions": [
          "latest(meter_elasticsearch_index_indices_store_size_bytes_primary)/1024/1024/1024"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "decimal",
        "unit": "GB"
      },
      {
        "id": "docs",
        "title": "Documents",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_index_indices_docs_total",
          "meter_elasticsearch_index_indices_docs_primary",
          "latest(meter_elasticsearch_index_indices_deleted_docs_primary)"
        ],
        "expressionLabels": [
          "all",
          "primary",
          "deleted"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "search_time",
        "title": "Avg Search Time / Req (s)",
        "type": "line",
        "expressions": [
          "meter_elasticsearch_index_search_fetch_avg_time",
          "meter_elasticsearch_index_search_query_avg_time",
          "meter_elasticsearch_index_search_scroll_avg_time",
          "meter_elasticsearch_index_search_suggest_avg_time"
        ],
        "expressionLabels": [
          "fetch",
          "query",
          "scroll",
          "suggest"
        ],
        "span": 12,
        "rowSpan": 2
      }
    ]
  }
}
