{
  "key": "AWS_GATEWAY",
  "alias": "AWS API Gateway",
  "group": "AWS",
  "color": "var(--sw-warn)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-aws-api-gateway-monitoring/",
  "aliases": {
    "services": "AWS Gateways",
    "endpoints": "Routes"
  },
  "components": {
    "service": true,
    "instances": false,
    "endpoints": true,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "count",
    "columns": [
      {
        "metric": "count",
        "label": "Requests",
        "mqe": "aws_gateway_service_count",
        "aggregation": "sum"
      },
      {
        "metric": "latency",
        "label": "Latency",
        "unit": "ms",
        "mqe": "aws_gateway_service_latency",
        "aggregation": "avg"
      },
      {
        "metric": "err4xx",
        "label": "4xx",
        "mqe": "aws_gateway_service_4xx",
        "aggregation": "sum"
      },
      {
        "metric": "err5xx",
        "label": "5xx",
        "mqe": "aws_gateway_service_5xx",
        "aggregation": "sum"
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "count",
        "title": "Request Count",
        "type": "line",
        "expressions": [
          "aws_gateway_service_count"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "err4xx",
        "title": "4xx Count",
        "type": "line",
        "expressions": [
          "aws_gateway_service_4xx"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "err5xx",
        "title": "5xx Count",
        "type": "line",
        "expressions": [
          "aws_gateway_service_5xx"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "latency",
        "title": "Request Avg Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "aws_gateway_service_latency"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "integration_latency",
        "title": "Integration Avg Latency",
        "tip": "Latency between the gateway and the backend integration.",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "aws_gateway_service_integration_latency"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "data",
        "title": "Data Processed (HTTP API only)",
        "type": "line",
        "unit": "KB",
        "expressions": [
          "aws_gateway_service_data_processed/1024"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "cache_hit",
        "title": "Cache Hit Rate (REST API only)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "aws_gateway_service_cache_hit_rate"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "cache_miss",
        "title": "Cache Miss Rate (REST API only)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "aws_gateway_service_cache_miss_rate"
        ],
        "span": 4,
        "rowSpan": 2
      }
    ],
    "endpoint": [
      {
        "id": "count",
        "title": "Request Count",
        "type": "line",
        "expressions": [
          "aws_gateway_endpoint_count"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "err4xx",
        "title": "4xx Count",
        "type": "line",
        "expressions": [
          "aws_gateway_endpoint_4xx"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "err5xx",
        "title": "5xx Count",
        "type": "line",
        "expressions": [
          "aws_gateway_endpoint_5xx"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "latency",
        "title": "Request Avg Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "aws_gateway_endpoint_latency"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "integration_latency",
        "title": "Integration Avg Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "aws_gateway_endpoint_integration_latency"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "data",
        "title": "Data Processed",
        "type": "line",
        "unit": "KB",
        "expressions": [
          "aws_gateway_endpoint_DataProcessed/1024"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "cache_hit",
        "title": "Cache Hit Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "aws_gateway_endpoint_cache_hit_rate"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "cache_miss",
        "title": "Cache Miss Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "aws_gateway_endpoint_cache_miss_rate"
        ],
        "span": 4,
        "rowSpan": 2
      }
    ]
  }
}
