{
  "key": "IOS",
  "alias": "iOS",
  "group": "Mobile",
  "color": "var(--sw-cyan)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-ios-monitoring/",
  "aliases": {
    "services": "Apps",
    "instances": "App Sessions",
    "endpoints": "Outbound APIs"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": true,
    "topology": false,
    "traces": false,
    "logs": true
  },
  "layer-header": {
    "orderBy": "launch",
    "columns": [
      {
        "metric": "launch",
        "label": "Launch (P95)",
        "unit": "ms",
        "mqe": "meter_ios_app_launch_time_percentile{p='95'}",
        "aggregation": "avg"
      },
      {
        "metric": "hangSum",
        "label": "Hang Time",
        "unit": "ms",
        "mqe": "meter_ios_hang_time_sum",
        "aggregation": "sum"
      },
      {
        "metric": "abnormalExit",
        "label": "Crashes",
        "mqe": "meter_ios_foreground_abnormal_exit_count + meter_ios_background_abnormal_exit_count",
        "aggregation": "sum"
      },
      {
        "metric": "outboundCpm",
        "label": "Outbound RPM",
        "unit": "rpm",
        "mqe": "service_cpm",
        "aggregation": "sum"
      }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "App health",
        "size": "auto",
        "metrics": [
          {
            "id": "launch_p95",
            "label": "Launch P95",
            "tip": "95th-percentile cold-launch time as measured by MetricKit.",
            "mqe": "meter_ios_app_launch_time_percentile{p='95'}",
            "unit": "ms",
            "aggregation": "avg"
          },
          {
            "id": "hang_p95",
            "label": "Hang P95",
            "tip": "95th-percentile UI hang duration.",
            "mqe": "meter_ios_hang_time_percentile{p='95'}",
            "unit": "ms",
            "aggregation": "avg"
          },
          {
            "id": "crashes",
            "label": "Crashes",
            "tip": "Foreground + background abnormal exits.",
            "mqe": "meter_ios_foreground_abnormal_exit_count + meter_ios_background_abnormal_exit_count",
            "aggregation": "sum"
          }
        ]
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "launch_percentile",
        "title": "App Launch Time Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_ios_app_launch_time_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "hang_percentile",
        "title": "Hang Time Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_ios_hang_time_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "hang_sum",
        "title": "Hang Time (sum)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_ios_hang_time_sum"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "abnormal_exits",
        "title": "Abnormal Exits (Crashes)",
        "tip": "MetricKit reports foreground vs background abnormal exits separately.",
        "type": "line",
        "expressions": [
          "meter_ios_foreground_abnormal_exit_count",
          "meter_ios_background_abnormal_exit_count"
        ],
        "expressionLabels": [
          "foreground",
          "background"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "oom_kills",
        "title": "OOM Kill Count",
        "tip": "Background OOM kills \u2014 the iOS system reaping the app due to memory pressure.",
        "type": "line",
        "expressions": [
          "meter_ios_background_oom_kill_count"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "peak_memory",
        "title": "Peak Memory",
        "type": "line",
        "unit": "bytes",
        "expressions": [
          "meter_ios_peak_memory"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "scroll_hitch",
        "title": "Scroll Hitch Ratio",
        "tip": "Percentage of scroll frames classified as hitched \u2014 higher = laggier UI.",
        "type": "line",
        "expressions": [
          "meter_ios_scroll_hitch_ratio"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "network_transfer",
        "title": "Network Transfer",
        "tip": "Bytes over wifi vs cellular, in + out.",
        "type": "line",
        "unit": "bytes",
        "expressions": [
          "meter_ios_wifi_download",
          "meter_ios_wifi_upload",
          "meter_ios_cellular_download",
          "meter_ios_cellular_upload"
        ],
        "expressionLabels": [
          "wifi \u2193",
          "wifi \u2191",
          "cellular \u2193",
          "cellular \u2191"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "outbound_http",
        "title": "Outbound HTTP",
        "tip": "Calls the app makes to backends \u2014 load, latency, success rate.",
        "type": "line",
        "expressions": [
          "service_cpm",
          "service_resp_time",
          "service_sla/100"
        ],
        "expressionLabels": [
          "RPM",
          "Avg latency (ms)",
          "Success Rate (%)"
        ],
        "expressionAxes": [
          0,
          0,
          1
        ],
        "span": 6,
        "rowSpan": 2
      }
    ],
    "instance": [
      {
        "id": "instance_launch_p",
        "title": "Launch Time Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_ios_instance_app_launch_time_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "instance_hang_p",
        "title": "Hang Time Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_ios_instance_hang_time_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "instance_crashes",
        "title": "Abnormal Exits",
        "type": "line",
        "expressions": [
          "meter_ios_instance_foreground_abnormal_exit_count",
          "meter_ios_instance_background_abnormal_exit_count"
        ],
        "expressionLabels": [
          "foreground",
          "background"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_oom",
        "title": "OOM Kill Count",
        "type": "line",
        "expressions": [
          "meter_ios_instance_background_oom_kill_count"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_peak_mem",
        "title": "Peak Memory",
        "type": "line",
        "unit": "bytes",
        "expressions": [
          "meter_ios_instance_peak_memory"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_outbound",
        "title": "Outbound HTTP",
        "type": "line",
        "expressions": [
          "service_instance_cpm",
          "service_instance_resp_time",
          "service_instance_sla/100"
        ],
        "expressionLabels": [
          "RPM",
          "Avg latency (ms)",
          "Success Rate (%)"
        ],
        "expressionAxes": [
          0,
          0,
          1
        ],
        "span": 12,
        "rowSpan": 2
      }
    ],
    "endpoint": [
      {
        "id": "ep_cpm",
        "title": "Outbound Load",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "endpoint_cpm"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "ep_resp",
        "title": "Outbound Avg Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "endpoint_resp_time"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "ep_sla",
        "title": "Outbound Success Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "endpoint_sla/100"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "ep_percentile",
        "title": "Outbound Latency Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(endpoint_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 12,
        "rowSpan": 2
      }
    ]
  }
}
