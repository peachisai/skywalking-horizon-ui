{
  "key": "SO11Y_OAP",
  "alias": "OAP (self-obs)",
  "group": "Self-Observability",
  "color": "var(--sw-fg-2)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-setup/",
  "aliases": {
    "services": "OAP services",
    "instances": "OAP nodes"
  },
  "components": {
    "service": false,
    "instances": true,
    "endpoints": false,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "cpu",
    "columns": [
      {
        "metric": "cpu",
        "label": "Avg CPU",
        "unit": "%",
        "mqe": "avg(meter_oap_instance_cpu_percentage)",
        "aggregation": "avg"
      },
      {
        "metric": "persist",
        "label": "Persist",
        "unit": "/min",
        "mqe": "sum(meter_oap_instance_persistence_execute_count)",
        "aggregation": "sum"
      },
      {
        "metric": "graphql",
        "label": "GraphQL",
        "unit": "/min",
        "mqe": "sum(meter_oap_instance_graphql_query_count)",
        "aggregation": "sum"
      },
      {
        "metric": "graphqlErr",
        "label": "GraphQL err",
        "unit": "/min",
        "mqe": "sum(meter_oap_instance_graphql_query_error_count)",
        "aggregation": "sum"
      }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "OAP health",
        "size": "auto",
        "metrics": [
          {
            "id": "cpu",
            "label": "CPU %",
            "tip": "OAP process CPU usage averaged across instances.",
            "mqe": "avg(meter_oap_instance_cpu_percentage)",
            "unit": "%",
            "aggregation": "avg"
          },
          {
            "id": "graphqlErr",
            "label": "GraphQL Err",
            "tip": "GraphQL query errors per minute summed across instances.",
            "mqe": "sum(meter_oap_instance_graphql_query_error_count)",
            "aggregation": "sum"
          }
        ]
      }
    ]
  },
  "dashboards": {
    "instance": [
      {
        "id": "cpu",
        "title": "CPU (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "meter_oap_instance_cpu_percentage"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "mem",
        "title": "JVM Memory (MB)",
        "type": "line",
        "unit": "MB",
        "expressions": [
          "meter_oap_instance_jvm_memory_bytes_used/1024/1024"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "gc_count",
        "title": "GC Count / min",
        "type": "line",
        "expressions": [
          "meter_oap_instance_jvm_gc_count"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "gc_time",
        "title": "GC Time (ms / min)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_oap_instance_jvm_gc_time"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "buffer_pool",
        "title": "Buffer Pool (MB)",
        "type": "line",
        "unit": "MB",
        "expressions": [
          "meter_oap_instance_jvm_buffer_pool_bytes_used/1024/1024"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "threads",
        "title": "Thread Count",
        "type": "line",
        "expressions": [
          "meter_oap_jvm_thread_live_count",
          "meter_oap_jvm_thread_peak_count",
          "meter_oap_jvm_thread_daemon_count"
        ],
        "expressionLabels": [
          "live",
          "peak",
          "daemon"
        ],
        "span": 5,
        "rowSpan": 2
      },
      {
        "id": "thread_states",
        "title": "Thread States",
        "type": "line",
        "expressions": [
          "meter_oap_jvm_thread_runnable_count",
          "meter_oap_jvm_thread_timed_waiting_count",
          "meter_oap_jvm_thread_blocked_count",
          "meter_oap_jvm_thread_waiting_count"
        ],
        "expressionLabels": [
          "runnable",
          "timed-waiting",
          "blocked",
          "waiting"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "classes",
        "title": "Class Count",
        "type": "line",
        "expressions": [
          "meter_oap_jvm_class_loaded_count",
          "meter_oap_jvm_class_total_unloaded_count",
          "meter_oap_jvm_class_total_loaded_count"
        ],
        "expressionLabels": [
          "loaded",
          "unloaded total",
          "loaded total"
        ],
        "span": 12,
        "rowSpan": 2
      },
      {
        "id": "aggregation",
        "title": "Aggregation / min",
        "type": "line",
        "expressions": [
          "meter_oap_instance_metrics_aggregation"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "persistence_counts",
        "title": "Persistence Counts / min",
        "type": "line",
        "expressions": [
          "meter_oap_instance_persistence_prepare_count",
          "meter_oap_instance_persistence_execute_count"
        ],
        "expressionLabels": [
          "prepare",
          "execute"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "persistence_cache",
        "title": "Persistent Cache / min",
        "type": "line",
        "expressions": [
          "meter_oap_instance_metrics_persistent_cache"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "persist_prepare_latency",
        "title": "Persistence Prepare Latency (ms)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_oap_instance_persistence_prepare_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "persist_execute_latency",
        "title": "Persistence Execute Latency (ms)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_oap_instance_persistence_execute_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "graphql_latency",
        "title": "GraphQL Latency (ms)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_oap_graphql_query_latency_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "graphql_count",
        "title": "GraphQL Query Count",
        "type": "line",
        "expressions": [
          "meter_oap_instance_graphql_query_count",
          "meter_oap_instance_graphql_query_error_count"
        ],
        "expressionLabels": [
          "queries",
          "errors"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "trace_analysis",
        "title": "Trace Analysis / min",
        "type": "line",
        "expressions": [
          "meter_oap_instance_trace_count",
          "meter_oap_instance_trace_analysis_error_count"
        ],
        "expressionLabels": [
          "total",
          "errors"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "trace_latency",
        "title": "Trace Analysis Latency (ms)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_oap_instance_trace_latency_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "mesh_analysis",
        "title": "Mesh Analysis / min",
        "type": "line",
        "expressions": [
          "meter_oap_instance_mesh_count",
          "meter_oap_instance_mesh_analysis_error_count"
        ],
        "expressionLabels": [
          "total",
          "errors"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "mesh_latency",
        "title": "Mesh Analysis Latency (ms)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_oap_instance_mesh_latency_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "otel_received",
        "title": "OTEL Received / s",
        "type": "line",
        "expressions": [
          "meter_oap_otel_metrics_received",
          "meter_oap_otel_logs_received",
          "meter_oap_otel_spans_received"
        ],
        "expressionLabels": [
          "metrics",
          "logs",
          "spans"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "k8s_als",
        "title": "K8S ALS",
        "type": "line",
        "expressions": [
          "meter_oap_instance_k8s_als_count",
          "meter_oap_instance_k8s_als_drop",
          "meter_oap_instance_k8s_als_streams",
          "meter_oap_instance_k8s_als_error_streams"
        ],
        "expressionLabels": [
          "count",
          "dropped",
          "streams",
          "err streams"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "watermark",
        "title": "Watermark Circuit Breaker",
        "tip": "Cumulative break + recover counters per listener.",
        "type": "line",
        "expressions": [
          "meter_oap_instance_watermark_circuit_breaker_break_count",
          "meter_oap_instance_watermark_circuit_breaker_recover_count"
        ],
        "expressionLabels": [
          "break",
          "recover"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "aggr_queue",
        "title": "Aggregation Queue Usage (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "sort_values(meter_oap_instance_metrics_aggregation_queue_used_per_ten_thousand{level='1'},10,des,avg)/100",
          "sort_values(meter_oap_instance_metrics_aggregation_queue_used_per_ten_thousand{level='2'},10,des,avg)/100"
        ],
        "expressionLabels": [
          "L1",
          "L2"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "banyandb_latency",
        "title": "BanyanDB Write Latency (ms)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_oap_banyandb_write_latency_percentile{catalog='measure',operation='bulk_write'}",
          "meter_oap_banyandb_write_latency_percentile{catalog='stream',operation='bulk_write'}",
          "meter_oap_banyandb_write_latency_percentile{catalog='trace',operation='bulk_write'}",
          "meter_oap_banyandb_write_latency_percentile{catalog='stream',operation='single_write'}",
          "meter_oap_banyandb_write_latency_percentile{catalog='property'}"
        ],
        "expressionLabels": [
          "measure bulk",
          "stream bulk",
          "trace bulk",
          "stream single",
          "property"
        ],
        "visibleWhen": "meter_oap_banyandb_write_latency_percentile has value",
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "es_latency",
        "title": "Elasticsearch Write Latency (ms)",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_oap_elasticsearch_write_latency_percentile{operation='single_write,single_update,single_delete'}",
          "meter_oap_elasticsearch_write_latency_percentile{operation='bulk_write'}"
        ],
        "expressionLabels": [
          "single",
          "bulk"
        ],
        "visibleWhen": "meter_oap_elasticsearch_write_latency_percentile has value",
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "zipkin_drop",
        "title": "Zipkin Spans Dropped",
        "type": "line",
        "expressions": [
          "meter_oap_instance_spans_dropped_count"
        ],
        "span": 6,
        "rowSpan": 2
      }
    ]
  }
}
