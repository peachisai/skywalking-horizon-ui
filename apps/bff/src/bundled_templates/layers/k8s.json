{
  "key": "K8S",
  "alias": "Kubernetes",
  "group": "Kubernetes",
  "color": "var(--sw-info)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-k8s-monitoring/",
  "aliases": {
    "services": "Clusters",
    "instances": "Nodes"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": false,
    "endpointDependency": false,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "pods",
    "columns": [
      {
        "metric": "pods",
        "label": "Pods",
        "mqe": "k8s_cluster_pod_total",
        "aggregation": "sum"
      },
      {
        "metric": "nodes",
        "label": "Nodes",
        "mqe": "k8s_cluster_node_total",
        "aggregation": "sum"
      },
      {
        "metric": "namespaces",
        "label": "Namespaces",
        "mqe": "k8s_cluster_namespace_total",
        "aggregation": "sum"
      },
      {
        "metric": "deployments",
        "label": "Deployments",
        "mqe": "k8s_cluster_deployment_total",
        "aggregation": "sum"
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "node_total",
        "title": "Node Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_node_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "namespace_total",
        "title": "Namespace Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_namespace_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "deployment_total",
        "title": "Deployment Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_deployment_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "statefulset_total",
        "title": "StatefulSet Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_statefulset_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "daemonset_total",
        "title": "DaemonSet Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_daemonset_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "service_total",
        "title": "Service Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_service_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "pod_total",
        "title": "Pod Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_pod_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "container_total",
        "title": "Container Total",
        "type": "card",
        "expressions": [
          "latest(k8s_cluster_container_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "cpu_res",
        "title": "CPU Resources",
        "tip": "Cluster CPU capacity vs requests / limits / allocatable (millicores).",
        "type": "line",
        "expressions": [
          "k8s_cluster_cpu_cores",
          "k8s_cluster_cpu_cores_requests",
          "k8s_cluster_cpu_cores_limits",
          "k8s_cluster_cpu_cores_allocatable"
        ],
        "expressionLabels": [
          "Capacity",
          "Requests",
          "Limits",
          "Allocatable"
        ],
        "unit": "m",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "mem_res",
        "title": "Memory Resources",
        "tip": "Cluster memory requests / allocatable / limits / total.",
        "type": "line",
        "expressions": [
          "k8s_cluster_memory_requests/1024/1024/1024",
          "k8s_cluster_memory_allocatable/1024/1024/1024",
          "k8s_cluster_memory_limits/1024/1024/1024",
          "k8s_cluster_memory_total/1024/1024/1024"
        ],
        "expressionLabels": [
          "Requests",
          "Allocatable",
          "Limits",
          "Total"
        ],
        "unit": "Gi",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "storage_res",
        "title": "Storage Resources",
        "tip": "Cluster ephemeral-storage total vs allocatable.",
        "type": "line",
        "expressions": [
          "k8s_cluster_storage_total/1024/1024/1024",
          "k8s_cluster_storage_allocatable/1024/1024/1024"
        ],
        "expressionLabels": [
          "Total",
          "Allocatable"
        ],
        "unit": "Gi",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "node_status",
        "title": "Node Status",
        "tip": "Per-node Kubernetes conditions currently true/unknown (Ready, *Pressure, \u2026).",
        "type": "table",
        "expressions": [
          "latest(k8s_cluster_node_status)"
        ],
        "tableHeaders": [
          "Node \u00b7 Condition",
          ""
        ],
        "showTableValues": false,
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "deployment_status",
        "title": "Deployment Status",
        "tip": "Deployments reporting the Available condition.",
        "type": "table",
        "expressions": [
          "latest(k8s_cluster_deployment_status)"
        ],
        "tableHeaders": [
          "Deployment \u00b7 Available",
          ""
        ],
        "showTableValues": false,
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "deployment_replicas",
        "title": "Deployment Spec Replicas",
        "tip": "Desired replica count per deployment.",
        "type": "table",
        "expressions": [
          "latest(k8s_cluster_deployment_spec_replicas)"
        ],
        "tableHeaders": [
          "Deployment",
          "Replicas"
        ],
        "showTableValues": true,
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "service_pod_status",
        "title": "Service Status",
        "tip": "Pods backing each K8s Service, by phase (Running / Pending / Failed / \u2026).",
        "type": "table",
        "expressions": [
          "latest(k8s_cluster_service_pod_status)"
        ],
        "tableHeaders": [
          "Service \u00b7 Phase",
          ""
        ],
        "showTableValues": false,
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "pod_not_running",
        "title": "Pod Status Not Running",
        "tip": "Pods in any non-Running phase.",
        "type": "table",
        "expressions": [
          "latest(k8s_cluster_pod_status_not_running)"
        ],
        "tableHeaders": [
          "Pod \u00b7 Status",
          ""
        ],
        "showTableValues": false,
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "pod_waiting",
        "title": "Pod Status Waiting",
        "tip": "Containers in a waiting state, by reason.",
        "type": "table",
        "expressions": [
          "latest(k8s_cluster_pod_status_waiting)"
        ],
        "tableHeaders": [
          "Container \u00b7 Pod \u00b7 Reason",
          ""
        ],
        "showTableValues": false,
        "span": 4,
        "rowSpan": 2
      }
    ],
    "instance": [
      {
        "id": "node_status",
        "title": "Node Status",
        "type": "card",
        "expressions": [
          "latest(k8s_node_node_status)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "enum",
        "valueColors": {
          "Ready": "ok",
          "MemoryPressure": "warn",
          "DiskPressure": "warn",
          "PIDPressure": "warn",
          "NetworkUnavailable": "err"
        }
      },
      {
        "id": "node_pod_total",
        "title": "Pods on Node",
        "type": "line",
        "expressions": [
          "k8s_node_pod_total"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "node_cpu_usage",
        "title": "Node CPU Usage",
        "tip": "CPU usage in millicores.",
        "type": "line",
        "unit": "m",
        "expressions": [
          "k8s_node_cpu_usage"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "node_pod_count",
        "title": "Pod Total",
        "tip": "Pods currently scheduled on this node (all phases).",
        "type": "card",
        "expressions": [
          "latest(k8s_node_pod_total)"
        ],
        "span": 3,
        "rowSpan": 1,
        "format": "int"
      },
      {
        "id": "node_cpu_resources",
        "title": "Node CPU Resources",
        "type": "line",
        "unit": "m",
        "expressions": [
          "k8s_node_cpu_cores",
          "k8s_node_cpu_cores_allocatable",
          "k8s_node_cpu_cores_requests",
          "k8s_node_cpu_cores_limits"
        ],
        "expressionLabels": [
          "total",
          "allocatable",
          "requests",
          "limits"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "node_memory_usage",
        "title": "Node Memory Usage",
        "type": "line",
        "unit": "Gi",
        "expressions": [
          "k8s_node_memory_usage/1024/1024/1024"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "node_memory_resources",
        "title": "Node Memory Resources",
        "type": "line",
        "unit": "Gi",
        "expressions": [
          "k8s_node_memory_total/1024/1024/1024",
          "k8s_node_memory_allocatable/1024/1024/1024",
          "k8s_node_memory_requests/1024/1024/1024",
          "k8s_node_memory_limits/1024/1024/1024"
        ],
        "expressionLabels": [
          "total",
          "allocatable",
          "requests",
          "limits"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "node_network_io",
        "title": "Node Network I/O",
        "type": "line",
        "unit": "KB/s",
        "expressions": [
          "k8s_node_network_receive/1024",
          "k8s_node_network_transmit/1024"
        ],
        "expressionLabels": [
          "receive",
          "transmit"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "node_storage_resources",
        "title": "Node Storage Resources",
        "type": "line",
        "unit": "Gi",
        "expressions": [
          "k8s_node_storage_total/1024/1024/1024",
          "k8s_node_storage_allocatable/1024/1024/1024"
        ],
        "expressionLabels": [
          "total",
          "allocatable"
        ],
        "span": 6,
        "rowSpan": 2
      }
    ]
  },
  "traces": {
    "source": "zipkin"
  }
}
