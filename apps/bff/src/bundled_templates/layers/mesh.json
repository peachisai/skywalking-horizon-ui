{
  "key": "MESH",
  "alias": "Istio Managed SVCs",
  "group": "Istio",
  "color": "var(--sw-info)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/envoy/als_setting/",
  "aliases": {
    "services": "Services",
    "instances": "Sidecars",
    "endpoints": "Endpoints"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": true,
    "endpointDependency": false,
    "topology": true,
    "traces": true,
    "logs": true,
    "ebpfProfiling": true
  },
  "layer-header": {
    "orderBy": "cpm",
    "columns": [
      {
        "metric": "cpm",
        "label": "Traffic",
        "unit": "rpm",
        "mqe": "service_cpm",
        "aggregation": "sum"
      },
      {
        "metric": "apdex",
        "label": "Apdex",
        "mqe": "service_apdex/10000",
        "aggregation": "avg"
      },
      {
        "metric": "respTime",
        "label": "Latency",
        "unit": "ms",
        "mqe": "service_resp_time",
        "aggregation": "avg"
      },
      {
        "metric": "err",
        "label": "Error Rate",
        "unit": "%",
        "mqe": "100 - service_sla/100",
        "aggregation": "avg"
      }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "Latency & errors",
        "size": "auto",
        "metrics": [
          {
            "id": "p95",
            "label": "P95",
            "tip": "95th-percentile sidecar-routed response time across the mesh.",
            "mqe": "service_percentile{p='95'}",
            "unit": "ms",
            "aggregation": "avg"
          },
          {
            "id": "err",
            "label": "Error Rate",
            "tip": "100 \u2212 mesh SLA. Calls with non-2xx response status from sidecar ALS.",
            "mqe": "100 - service_sla/100",
            "unit": "%",
            "aggregation": "avg"
          }
        ]
      },
      {
        "title": "Health",
        "size": "square",
        "metrics": [
          {
            "id": "apdex",
            "label": "Apdex",
            "tip": "User-satisfaction score on a 0 \u2013 1 scale.",
            "mqe": "service_apdex/10000",
            "aggregation": "avg"
          }
        ]
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "top_apis",
        "title": "Top 20 APIs",
        "tip": "Layer-wide endpoint ranking. Switch tabs to re-rank by traffic, response time, or worst success rate.",
        "type": "top",
        "expressions": [
          "top_n(endpoint_cpm,20,des)",
          "top_n(endpoint_resp_time,20,des)",
          "top_n(endpoint_sla,20,asc)/100"
        ],
        "expressionLabels": [
          "Traffic",
          "Slow",
          "Successful Rate"
        ],
        "expressionUnits": [
          "rpm",
          "ms",
          "%"
        ],
        "layerScope": true,
        "span": 3,
        "rowSpan": 4
      },
      {
        "id": "traffic_line",
        "title": "Traffic",
        "tip": "Mesh-wide requests per minute observed by Envoy sidecars.",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "service_cpm"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "err_line",
        "title": "Error Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "100 - service_sla/100"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "apdex_line",
        "title": "Apdex",
        "tip": "User-satisfaction score on a 0 \u2013 1 scale.",
        "type": "line",
        "expressions": [
          "service_apdex/10000"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "resp_time_line",
        "title": "Avg Response Time",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "service_resp_time"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "percentile_line",
        "title": "Response Time Percentile",
        "tip": "p50 / p75 / p90 / p95 / p99 latency \u2014 the tail of the response-time distribution.",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(service_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "throughput_line",
        "title": "Service Throughput",
        "tip": "Bytes per minute through the sidecar \u2014 sent + received.",
        "type": "line",
        "unit": "B/min",
        "expressions": [
          "service_throughput_received",
          "service_throughput_sent"
        ],
        "expressionLabels": [
          "received",
          "sent"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "sidecar_internal_latency",
        "title": "Sidecar Internal Latency",
        "tip": "Envoy-internal request + response latency, in nanoseconds. Useful when sidecar overhead is suspected.",
        "type": "line",
        "unit": "ns",
        "expressions": [
          "service_sidecar_internal_req_latency_nanos",
          "service_sidecar_internal_resp_latency_nanos"
        ],
        "expressionLabels": [
          "request",
          "response"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "top_instances",
        "title": "Top 10 sidecars",
        "tip": "Ranked across the selected service's sidecar instances.",
        "type": "top",
        "expressions": [
          "top_n(service_instance_cpm,10,des)",
          "top_n(service_instance_resp_time,10,des)",
          "top_n(service_instance_sla,10,asc)/100"
        ],
        "expressionLabels": [
          "Traffic",
          "Slow",
          "Successful Rate"
        ],
        "expressionUnits": [
          "rpm",
          "ms",
          "%"
        ],
        "span": 6,
        "rowSpan": 3
      },
      {
        "id": "top_endpoints_in_service",
        "title": "Top 10 endpoints in service",
        "tip": "Ranked across the selected service's endpoints.",
        "type": "top",
        "expressions": [
          "top_n(endpoint_cpm,10,des)",
          "top_n(endpoint_resp_time,10,des)",
          "top_n(endpoint_sla,10,asc)/100"
        ],
        "expressionLabels": [
          "Traffic",
          "Slow",
          "Successful Rate"
        ],
        "expressionUnits": [
          "rpm",
          "ms",
          "%"
        ],
        "span": 6,
        "rowSpan": 3
      }
    ],
    "instance": [
      {
        "id": "instance_cpm_line",
        "title": "Sidecar Load",
        "tip": "Calls per minute against the selected sidecar instance.",
        "type": "line",
        "unit": "calls / min",
        "expressions": [
          "service_instance_cpm"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_resp_line",
        "title": "Sidecar Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "service_instance_resp_time"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_sla_line",
        "title": "Sidecar Success Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "service_instance_sla/100"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_throughput",
        "title": "Sidecar Throughput",
        "tip": "Bytes through the sidecar \u2014 received + sent.",
        "type": "line",
        "unit": "B/min",
        "expressions": [
          "service_instance_throughput_received",
          "service_instance_throughput_sent"
        ],
        "expressionLabels": [
          "received",
          "sent"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "instance_sidecar_internal_latency",
        "title": "Sidecar Internal Latency",
        "type": "line",
        "unit": "ns",
        "expressions": [
          "service_instance_sidecar_internal_req_latency_nanos",
          "service_instance_sidecar_internal_resp_latency_nanos"
        ],
        "expressionLabels": [
          "request",
          "response"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "envoy_up_rq_active",
        "title": "Envoy Upstream Request Active",
        "tip": "In-flight upstream requests per cluster. Renders for Envoy-instrumented sidecars.",
        "type": "line",
        "expressions": [
          "envoy_cluster_up_rq_active"
        ],
        "visibleWhen": "envoy_cluster_up_rq_active has value",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "envoy_up_rq_incr",
        "title": "Envoy Upstream Request Increase",
        "tip": "Upstream requests added per minute.",
        "type": "line",
        "expressions": [
          "envoy_cluster_up_rq_incr"
        ],
        "visibleWhen": "envoy_cluster_up_rq_incr has value",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "envoy_up_rq_pending_active",
        "title": "Envoy Upstream Pending Active",
        "tip": "Pending upstream requests \u2014 indicates connection-pool back-pressure.",
        "type": "line",
        "expressions": [
          "envoy_cluster_up_rq_pending_active"
        ],
        "visibleWhen": "envoy_cluster_up_rq_pending_active has value",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "envoy_up_cx_active",
        "title": "Envoy Upstream Connection Active",
        "type": "line",
        "expressions": [
          "envoy_cluster_up_cx_active"
        ],
        "visibleWhen": "envoy_cluster_up_cx_active has value",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "envoy_up_cx_incr",
        "title": "Envoy Upstream Connection Increase",
        "type": "line",
        "expressions": [
          "envoy_cluster_up_cx_incr"
        ],
        "visibleWhen": "envoy_cluster_up_cx_incr has value",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "envoy_membership_healthy",
        "title": "Envoy Cluster Healthy Membership",
        "tip": "Healthy upstream members per cluster \u2014 a non-trivial drop signals upstream churn.",
        "type": "line",
        "expressions": [
          "envoy_cluster_membership_healthy"
        ],
        "visibleWhen": "envoy_cluster_membership_healthy has value",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "envoy_connections",
        "title": "Envoy Total Connections",
        "type": "line",
        "expressions": [
          "envoy_total_connections_used",
          "envoy_parent_connections_used"
        ],
        "expressionLabels": [
          "total",
          "parent"
        ],
        "visibleWhen": "envoy_total_connections_used has value",
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "envoy_heap_memory",
        "title": "Envoy Heap Memory",
        "tip": "Envoy memory usage. Heap vs physical, allocated vs max, in MB.",
        "type": "line",
        "unit": "MB",
        "expressions": [
          "envoy_heap_memory_used/1024/1024",
          "envoy_heap_memory_max_used/1024/1024",
          "envoy_memory_allocated/1024/1024",
          "envoy_memory_allocated_max/1024/1024",
          "envoy_memory_physical_size/1024/1024",
          "envoy_memory_physical_size_max/1024/1024"
        ],
        "expressionLabels": [
          "heap used",
          "heap max",
          "allocated",
          "allocated max",
          "physical",
          "physical max"
        ],
        "visibleWhen": "envoy_heap_memory_used has value",
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "envoy_worker_threads",
        "title": "Envoy Worker Threads",
        "type": "line",
        "expressions": [
          "envoy_worker_threads",
          "envoy_worker_threads_max"
        ],
        "expressionLabels": [
          "live",
          "max"
        ],
        "visibleWhen": "envoy_worker_threads has value",
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "envoy_bug_failures",
        "title": "Envoy Bug Failures",
        "tip": "Envoy's own assertion / bug counter. Should be zero in healthy clusters.",
        "type": "line",
        "expressions": [
          "envoy_bug_failures"
        ],
        "visibleWhen": "envoy_bug_failures has value",
        "span": 3,
        "rowSpan": 2
      }
    ],
    "endpoint": [
      {
        "id": "endpoint_cpm_line",
        "title": "Endpoint Traffic",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "endpoint_cpm"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "endpoint_resp_line",
        "title": "Endpoint Avg Response Time",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "endpoint_resp_time"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "endpoint_sla_line",
        "title": "Endpoint Success Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "endpoint_sla/100"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "endpoint_percentile",
        "title": "Endpoint Response Time Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(endpoint_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 12,
        "rowSpan": 2
      },
      {
        "id": "endpoint_sidecar_internal_latency",
        "title": "Sidecar Internal Latency (endpoint scope)",
        "tip": "Envoy-internal request + response latency on this endpoint, in nanoseconds.",
        "type": "line",
        "unit": "ns",
        "expressions": [
          "endpoint_sidecar_internal_req_latency_nanos",
          "endpoint_sidecar_internal_resp_latency_nanos"
        ],
        "expressionLabels": [
          "request",
          "response"
        ],
        "span": 12,
        "rowSpan": 2
      }
    ],
    "trace": [],
    "ebpfProfiling": []
  },
  "topology": {
    "nodeMetrics": [
      {
        "id": "cpm",
        "label": "RPM",
        "mqe": "service_cpm",
        "unit": "rpm",
        "role": "center",
        "aggregation": "avg"
      },
      {
        "id": "sla",
        "label": "SLA",
        "mqe": "service_sla/100",
        "unit": "%",
        "role": "ring",
        "aggregation": "avg",
        "thresholds": {
          "invertHealth": true,
          "invertBase": 100,
          "ok": 0.1,
          "warn": 1,
          "danger": 5
        }
      },
      {
        "id": "respTime",
        "label": "Latency",
        "mqe": "service_resp_time",
        "unit": "ms",
        "role": "secondary",
        "aggregation": "avg"
      }
    ],
    "linkServerMetrics": [
      {
        "id": "cpm",
        "label": "RPM",
        "mqe": "service_relation_server_cpm",
        "unit": "rpm",
        "role": "lineServer",
        "aggregation": "avg"
      },
      {
        "id": "respTime",
        "label": "Avg response time",
        "mqe": "service_relation_server_resp_time",
        "unit": "ms",
        "aggregation": "avg"
      },
      {
        "id": "p95",
        "label": "p95",
        "mqe": "service_relation_server_percentile{p='95'}",
        "unit": "ms",
        "aggregation": "avg"
      },
      {
        "id": "sla",
        "label": "SLA",
        "mqe": "service_relation_server_call_sla/100",
        "unit": "%",
        "aggregation": "avg"
      }
    ],
    "linkClientMetrics": [
      {
        "id": "cpm",
        "label": "RPM",
        "mqe": "service_relation_client_cpm",
        "unit": "rpm",
        "role": "lineClient",
        "aggregation": "avg"
      },
      {
        "id": "respTime",
        "label": "Avg response time",
        "mqe": "service_relation_client_resp_time",
        "unit": "ms",
        "aggregation": "avg"
      },
      {
        "id": "p95",
        "label": "p95",
        "mqe": "service_relation_client_percentile{p='95'}",
        "unit": "ms",
        "aggregation": "avg"
      },
      {
        "id": "sla",
        "label": "SLA",
        "mqe": "service_relation_client_call_sla/100",
        "unit": "%",
        "aggregation": "avg"
      }
    ]
  }
}
