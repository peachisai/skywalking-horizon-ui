{
  "key": "ALIPAY_MINI_PROGRAM",
  "alias": "Alipay Mini Program",
  "group": "Mobile",
  "color": "var(--sw-cyan)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-alipay-mini-program-monitoring/",
  "aliases": {
    "services": "Mini-programs",
    "instances": "Versions",
    "endpoints": "Pages"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": true,
    "topology": false,
    "traces": true,
    "logs": true
  },
  "layer-header": {
    "orderBy": "cpm",
    "columns": [
      {
        "metric": "cpm",
        "label": "Request RPM",
        "unit": "rpm",
        "mqe": "meter_alipay_mp_request_cpm",
        "aggregation": "sum"
      },
      {
        "metric": "launch",
        "label": "Launch",
        "unit": "ms",
        "mqe": "meter_alipay_mp_app_launch_duration",
        "aggregation": "avg"
      },
      {
        "metric": "firstRender",
        "label": "First Render",
        "unit": "ms",
        "mqe": "meter_alipay_mp_first_render_duration",
        "aggregation": "avg"
      },
      {
        "metric": "errors",
        "label": "Errors",
        "mqe": "meter_alipay_mp_error_count",
        "aggregation": "sum"
      }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "Latency & errors",
        "size": "auto",
        "metrics": [
          {
            "id": "request_p95",
            "label": "Request P95",
            "tip": "95th-percentile request duration from the mini-program network bridge.",
            "mqe": "meter_alipay_mp_request_duration_percentile{p='95'}",
            "unit": "ms",
            "aggregation": "avg"
          },
          {
            "id": "launch",
            "label": "Launch",
            "tip": "Approximate mini-program launch duration.",
            "mqe": "meter_alipay_mp_app_launch_duration",
            "unit": "ms",
            "aggregation": "avg"
          },
          {
            "id": "errors",
            "label": "Errors",
            "tip": "Reported error count.",
            "mqe": "meter_alipay_mp_error_count",
            "aggregation": "sum"
          }
        ]
      },
      {
        "title": "Throughput",
        "size": "square",
        "metrics": [
          {
            "id": "cpm",
            "label": "Request RPM",
            "tip": "Bridge requests per minute.",
            "mqe": "meter_alipay_mp_request_cpm",
            "unit": "rpm",
            "aggregation": "sum"
          }
        ]
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "launch_duration",
        "title": "App Launch Duration",
        "tip": "Approximate cold-launch duration from the Alipay container.",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_alipay_mp_app_launch_duration"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "first_render",
        "title": "First Render Duration",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_alipay_mp_first_render_duration"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "error_count",
        "title": "Error Count",
        "type": "line",
        "expressions": [
          "meter_alipay_mp_error_count"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "request_cpm",
        "title": "Request Load",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "meter_alipay_mp_request_cpm"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "request_percentile",
        "title": "Request Duration Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_alipay_mp_request_duration_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 6,
        "rowSpan": 2
      }
    ],
    "instance": [
      {
        "id": "v_launch",
        "title": "Launch Duration",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_alipay_mp_instance_app_launch_duration"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "v_first_render",
        "title": "First Render Duration",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_alipay_mp_instance_first_render_duration"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "v_request_cpm",
        "title": "Request Load",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "meter_alipay_mp_instance_request_cpm"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "v_request_percentile",
        "title": "Request Duration Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_alipay_mp_instance_request_duration_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 12,
        "rowSpan": 2
      }
    ],
    "endpoint": [
      {
        "id": "ep_launch",
        "title": "Launch Duration on Page",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_alipay_mp_endpoint_app_launch_duration"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "ep_first_render",
        "title": "First Render Duration",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_alipay_mp_endpoint_first_render_duration"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "ep_request_cpm",
        "title": "Request Load",
        "type": "line",
        "unit": "rpm",
        "expressions": [
          "meter_alipay_mp_endpoint_request_cpm"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "ep_request_percentile",
        "title": "Request Duration Percentile",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "relabels(meter_alipay_mp_endpoint_request_duration_percentile{p='50,75,90,95,99'},p='50,75,90,95,99',percentile='50,75,90,95,99')"
        ],
        "span": 12,
        "rowSpan": 2
      }
    ]
  }
}
