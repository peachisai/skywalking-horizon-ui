        ],
        "span": 4,
        "rowSpan": 2
      }
    ]
  },
  "topology": {
    "nodeMetrics": [
      {
        "id": "cpm",
        "label": "RPM",
        "mqe": "cilium_service_protocol_cpm",
        "unit": "rpm",
        "role": "center",
        "aggregation": "avg"
      },
      {
        "id": "success",
        "label": "Success %",
        "mqe": "cilium_service_protocol_call_success_count/cilium_service_protocol_cpm*100",
        "unit": "%",
        "role": "ring",
        "aggregation": "avg"
      },
      {
        "id": "respTime",
        "label": "Latency",
        "mqe": "cilium_service_protocol_call_duration/cilium_service_protocol_cpm/1000000",
        "unit": "ms",
        "role": "secondary",
        "aggregation": "avg"
      }
    ],
    "linkServerMetrics": [
      {
        "id": "cpm",
        "label": "HTTP RPM",
        "mqe": "cilium_service_relation_server_protocol_http_call_cpm",
        "unit": "rpm",
        "role": "lineServer",
        "aggregation": "avg"
      },
      {
        "id": "respTime",
        "label": "Avg Latency",
        "mqe": "cilium_service_relation_server_protocol_http_call_duration/cilium_service_relation_server_protocol_http_call_cpm/1000000",
        "unit": "ms",
        "aggregation": "avg"
      }
    ]
  }
}
