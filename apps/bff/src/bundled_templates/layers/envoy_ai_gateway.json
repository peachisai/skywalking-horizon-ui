        "rowSpan": 2
      },
      {
        "id": "mcp_latency",
        "title": "MCP Avg Latency",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "meter_envoy_ai_gw_mcp_request_latency_avg"
        ],
