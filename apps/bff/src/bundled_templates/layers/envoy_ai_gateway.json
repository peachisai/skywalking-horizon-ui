        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "model_latency",
        "title": "Latency Avg by Model",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "aggregate_labels(meter_envoy_ai_gw_model_latency_avg,avg(gen_ai_response_model))"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "model_ttft",
        "title": "TTFT by Model",
        "type": "line",
        "unit": "ms",
        "expressions": [
          "aggregate_labels(meter_envoy_ai_gw_model_ttft_avg,avg(gen_ai_response_model))"
