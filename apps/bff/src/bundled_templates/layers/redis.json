{
  "key": "REDIS",
  "alias": "Redis",
  "group": "Databases",
  "color": "var(--sw-warn)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-redis-monitoring/",
  "aliases": {
    "services": "Redis clusters",
    "instances": "Nodes"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": false,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "cmds",
    "columns": [
      {
        "metric": "cmds",
        "label": "Commands/s",
        "mqe": "aggregate_labels(meter_redis_total_commands_rate,sum(cmd))",
        "aggregation": "sum"
      },
      {
        "metric": "hitRate",
        "label": "Hit Rate",
        "unit": "%",
        "mqe": "aggregate_labels(meter_redis_hit_rate,avg)",
        "aggregation": "avg"
      },
      {
        "metric": "memUsage",
        "label": "Memory %",
        "unit": "%",
        "mqe": "latest(aggregate_labels(meter_redis_memory_used_bytes,sum)/aggregate_labels(meter_redis_memory_max_bytes,sum))*100",
        "aggregation": "avg"
      },
      {
        "metric": "conns",
        "label": "Clients",
        "mqe": "latest(aggregate_labels(meter_redis_connected_clients,sum))",
        "aggregation": "sum"
      }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "Health",
        "size": "auto",
        "metrics": [
          {
            "id": "hitRate",
            "label": "Hit Rate",
            "tip": "Cache hit ratio. Trending down = thrash.",
            "mqe": "aggregate_labels(meter_redis_hit_rate,avg)",
            "unit": "%",
            "aggregation": "avg"
          },
          {
            "id": "memUsage",
            "label": "Memory %",
            "tip": "Used / max memory. >80% = warn.",
            "mqe": "latest(aggregate_labels(meter_redis_memory_used_bytes,sum)/aggregate_labels(meter_redis_memory_max_bytes,sum))*100",
            "unit": "%",
            "aggregation": "avg"
          }
        ]
      },
      {
        "title": "Throughput",
        "size": "square",
        "metrics": [
          {
            "id": "cmds",
            "label": "Commands/s",
            "tip": "Total commands per second across the cluster.",
            "mqe": "aggregate_labels(meter_redis_total_commands_rate,sum(cmd))",
            "aggregation": "sum"
          }
        ]
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "uptime",
        "title": "Uptime (days)",
        "type": "line",
        "expressions": [
          "latest(aggregate_labels(meter_redis_uptime,max))/3600/24"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "clients",
        "title": "Connected Clients",
        "type": "line",
        "expressions": [
          "latest(aggregate_labels(meter_redis_connected_clients,sum))"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "blocked",
        "title": "Blocked Clients",
        "type": "line",
        "expressions": [
          "latest(aggregate_labels(meter_redis_blocked_clients,sum))"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "mem_pct",
        "title": "Memory Usage",
        "type": "line",
        "unit": "%",
        "expressions": [
          "latest(aggregate_labels(meter_redis_memory_used_bytes,sum)/aggregate_labels(meter_redis_memory_max_bytes,sum))*100"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "commands",
        "title": "Total Commands / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_redis_total_commands_rate,sum(cmd))"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "hit_rate",
        "title": "Hit Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "aggregate_labels(meter_redis_hit_rate,avg)"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "avg_cmd_time",
        "title": "Avg Command Time / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_redis_commands_duration,sum(cmd))/aggregate_labels(meter_redis_commands_total,sum(cmd))"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "net_io",
        "title": "Net I/O (KB)",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_redis_net_input_bytes_total,sum)/1024",
          "aggregate_labels(meter_redis_net_output_bytes_total,sum)/1024"
        ],
        "expressionLabels": [
          "in",
          "out"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "db_keys",
        "title": "Keys",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_redis_db_keys,sum)",
          "aggregate_labels(meter_redis_evicted_keys_total,sum)",
          "aggregate_labels(meter_redis_expired_keys_total,sum)"
        ],
        "expressionLabels": [
          "total",
          "evicted",
          "expired"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "slow_cmds",
        "title": "Slow Commands",
        "tip": "Top 10 slowest captured commands. Captured by SkyWalking agent at the call-site.",
        "type": "record",
        "unit": "ms",
        "expressions": [
          "top_n(top_n_database_statement,10,des)"
        ],
        "span": 12,
        "rowSpan": 4
      }
    ],
    "instance": [
      {
        "id": "uptime",
        "title": "Uptime (days)",
        "type": "line",
        "expressions": [
          "latest(meter_redis_instance_uptime)/3600/24"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "clients",
        "title": "Connected Clients",
        "type": "line",
        "expressions": [
          "latest(meter_redis_instance_connected_clients)"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "blocked",
        "title": "Blocked Clients",
        "type": "line",
        "expressions": [
          "latest(meter_redis_instance_redis_blocked_clients)"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "max_mem",
        "title": "Memory Max (MB)",
        "type": "line",
        "expressions": [
          "latest(meter_redis_instance_memory_max_bytes)/1000/1000"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "mem_pct",
        "title": "Memory Usage (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "meter_redis_instance_memory_usage"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "cmds",
        "title": "Commands / s",
        "type": "line",
        "expressions": [
          "meter_redis_instance_total_commands_rate"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "hit_rate",
        "title": "Hit Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "meter_redis_instance_hit_rate"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "net_io",
        "title": "Net I/O (KB)",
        "type": "line",
        "expressions": [
          "meter_redis_instance_net_input_bytes_total/1024",
          "meter_redis_instance_net_output_bytes_total/1024"
        ],
        "expressionLabels": [
          "in",
          "out"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "db_keys",
        "title": "Keys",
        "type": "line",
        "expressions": [
          "meter_redis_instance_db_keys",
          "meter_redis_instance_evicted_keys_total",
          "meter_redis_instance_expired_keys_total"
        ],
        "expressionLabels": [
          "total",
          "evicted",
          "expired"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "cmd_dur",
        "title": "Total Command Time (s)",
        "type": "line",
        "expressions": [
          "meter_redis_instance_commands_duration_seconds_total_rate"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "avg_cmd_time",
        "title": "Avg Command Time",
        "type": "line",
        "expressions": [
          "meter_redis_instance_average_time_spent_by_command"
        ],
        "span": 6,
        "rowSpan": 2
      }
    ]
  }
}
