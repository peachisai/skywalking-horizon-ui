{
  "key": "POSTGRESQL",
  "alias": "PostgreSQL",
  "group": "Databases",
  "color": "var(--sw-warn)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-postgresql-monitoring/",
  "aliases": {
    "services": "PostgreSQL clusters",
    "instances": "Nodes"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": false,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "fetched",
    "columns": [
      {
        "metric": "fetched",
        "label": "Fetched / s",
        "mqe": "aggregate_labels(meter_pg_fetched_rows_rate,sum)",
        "aggregation": "sum"
      },
      {
        "metric": "inserted",
        "label": "Inserted / s",
        "mqe": "aggregate_labels(meter_pg_inserted_rows_rate,sum)",
        "aggregation": "sum"
      },
      {
        "metric": "cacheHit",
        "label": "Cache Hit",
        "unit": "%",
        "mqe": "aggregate_labels(meter_pg_cache_hit_rate,avg)",
        "aggregation": "avg"
      },
      {
        "metric": "deadlocks",
        "label": "Deadlocks",
        "mqe": "aggregate_labels(meter_pg_deadlocks_rate,sum)",
        "aggregation": "sum"
      }
    ]
  },
  "overview": {
    "groups": [
      {
        "title": "Health",
        "size": "auto",
        "metrics": [
          {
            "id": "cacheHit",
            "label": "Cache Hit",
            "tip": "Buffer-cache hit ratio across the cluster.",
            "mqe": "aggregate_labels(meter_pg_cache_hit_rate,avg)",
            "unit": "%",
            "aggregation": "avg"
          },
          {
            "id": "deadlocks",
            "label": "Deadlocks/s",
            "tip": "Detected deadlocks per second.",
            "mqe": "aggregate_labels(meter_pg_deadlocks_rate,sum)",
            "aggregation": "sum"
          },
          {
            "id": "conflicts",
            "label": "Conflicts/s",
            "tip": "Recovery conflicts per second.",
            "mqe": "aggregate_labels(meter_pg_conflicts_rate,sum)",
            "aggregation": "sum"
          }
        ]
      },
      {
        "title": "Throughput",
        "size": "square",
        "metrics": [
          {
            "id": "fetched",
            "label": "Fetched /s",
            "tip": "Rows fetched per second.",
            "mqe": "aggregate_labels(meter_pg_fetched_rows_rate,sum)",
            "aggregation": "sum"
          }
        ]
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "rows_fetched",
        "title": "Fetched Rows / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_fetched_rows_rate,sum)"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "rows_inserted",
        "title": "Inserted Rows / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_inserted_rows_rate,sum)"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "rows_updated",
        "title": "Updated Rows / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_updated_rows_rate,sum)"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "rows_deleted",
        "title": "Deleted Rows / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_deleted_rows_rate,sum)"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "rows_returned",
        "title": "Returned Rows / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_returned_rows_rate,sum)"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "temp_files",
        "title": "Temporary Files / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_temporary_files_rate,sum)"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "cache_hit",
        "title": "Cache Hit Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "aggregate_labels(meter_pg_cache_hit_rate,avg)"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "txn_rates",
        "title": "Transactions / s",
        "tip": "Committed vs rolled-back.",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_committed_transactions_rate,sum)",
          "aggregate_labels(meter_pg_rolled_back_transactions_rate,sum)"
        ],
        "expressionLabels": [
          "committed",
          "rolled-back"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "conflicts_deadlocks",
        "title": "Conflicts + Deadlocks / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_conflicts_rate,sum)",
          "aggregate_labels(meter_pg_deadlocks_rate,sum)"
        ],
        "expressionLabels": [
          "conflicts",
          "deadlocks"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "sessions",
        "title": "Sessions",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_active_sessions,sum)",
          "aggregate_labels(meter_pg_idle_sessions,sum)",
          "aggregate_labels(meter_pg_locks_count,sum)"
        ],
        "expressionLabels": [
          "active",
          "idle",
          "locks"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "buffers",
        "title": "Buffers / s",
        "tip": "Checkpoint / clean / fsync / alloc / backend buffer activity.",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_buffers_checkpoint,sum)",
          "aggregate_labels(meter_pg_buffers_clean,sum)",
          "aggregate_labels(meter_pg_buffers_backend_fsync,sum)",
          "aggregate_labels(meter_pg_buffers_alloc,sum)",
          "aggregate_labels(meter_pg_buffers_backend,sum)"
        ],
        "expressionLabels": [
          "checkpoint",
          "clean",
          "backend fsync",
          "alloc",
          "backend"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "checkpoint_stats",
        "title": "Checkpoint Stats / s",
        "type": "line",
        "expressions": [
          "aggregate_labels(meter_pg_checkpoints_timed_rate,sum)",
          "aggregate_labels(meter_pg_checkpoint_req_rate,sum)",
          "aggregate_labels(meter_pg_checkpoint_write_time_rate,sum)",
          "aggregate_labels(meter_pg_checkpoint_sync_time_rate,sum)"
        ],
        "expressionLabels": [
          "timed",
          "requested",
          "write time",
          "sync time"
        ],
        "span": 12,
        "rowSpan": 2
      },
      {
        "id": "slow_statements",
        "title": "Slow Statements",
        "tip": "Top 20 slowest captured statements.",
        "type": "record",
        "unit": "ms",
        "expressions": [
          "top_n(top_n_database_statement, 20, des)"
        ],
        "span": 12,
        "rowSpan": 4
      }
    ],
    "instance": [
      {
        "id": "shared_buffers",
        "title": "Shared Buffers",
        "type": "line",
        "unit": "MB",
        "expressions": [
          "latest(meter_pg_instance_shared_buffers)/1024/1024"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "effective_cache",
        "title": "Effective Cache",
        "type": "line",
        "unit": "GB",
        "expressions": [
          "latest(meter_pg_instance_effective_cache)/1024/1024/1024"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "work_mem",
        "title": "Work Mem",
        "type": "line",
        "unit": "MB",
        "expressions": [
          "latest(meter_pg_instance_work_mem)/1024/1024"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "max_wal_size",
        "title": "Max WAL Size",
        "type": "line",
        "unit": "GB",
        "expressions": [
          "latest(meter_pg_instance_max_wal_size)/1024/1024/1024"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "instance_fetched",
        "title": "Fetched Rows / s",
        "type": "line",
        "expressions": [
          "meter_pg_instance_fetched_rows_rate"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_inserted",
        "title": "Inserted Rows / s",
        "type": "line",
        "expressions": [
          "meter_pg_instance_inserted_rows_rate"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_cache_hit",
        "title": "Cache Hit Rate",
        "type": "line",
        "unit": "%",
        "expressions": [
          "meter_pg_instance_cache_hit_rate"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "instance_sessions",
        "title": "Sessions",
        "type": "line",
        "expressions": [
          "meter_pg_instance_active_sessions",
          "meter_pg_instance_idle_sessions",
          "meter_pg_instance_locks_count"
        ],
        "expressionLabels": [
          "active",
          "idle",
          "locks"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "instance_conflicts",
        "title": "Conflicts + Deadlocks / s",
        "type": "line",
        "expressions": [
          "meter_pg_instance_conflicts_rate",
          "meter_pg_instance_deadlocks_rate"
        ],
        "expressionLabels": [
          "conflicts",
          "deadlocks"
        ],
        "span": 6,
        "rowSpan": 2
      }
    ]
  }
}
