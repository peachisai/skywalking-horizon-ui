{
  "key": "AWS_EKS",
  "alias": "AWS EKS",
  "group": "AWS",
  "color": "var(--sw-warn)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-aws-eks-monitoring/",
  "aliases": {
    "services": "Clusters",
    "instances": "Nodes",
    "endpoints": "EKS services"
  },
  "components": {
    "service": true,
    "instances": true,
    "endpoints": true,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "nodes",
    "columns": [
      {
        "metric": "nodes",
        "label": "Nodes",
        "mqe": "latest(eks_cluster_node_count)",
        "aggregation": "avg"
      },
      {
        "metric": "failedNodes",
        "label": "Failed Nodes",
        "mqe": "latest(eks_cluster_failed_node_count)",
        "aggregation": "avg"
      },
      {
        "metric": "namespaces",
        "label": "Namespaces",
        "mqe": "latest(eks_cluster_namespace_count)",
        "aggregation": "avg"
      },
      {
        "metric": "services",
        "label": "Services",
        "mqe": "latest(eks_cluster_service_count)",
        "aggregation": "avg"
      }
    ]
  },
  "dashboards": {
    "service": [
      {
        "id": "node_count",
        "title": "Node Count",
        "type": "line",
        "expressions": [
          "eks_cluster_node_count"
        ],
        "span": 3,
        "rowSpan": 2,
        "format": "int"
      },
      {
        "id": "failed_nodes",
        "title": "Failed Nodes",
        "type": "line",
        "expressions": [
          "eks_cluster_failed_node_count"
        ],
        "span": 3,
        "rowSpan": 2,
        "format": "int"
      },
      {
        "id": "namespace_count",
        "title": "Namespace Count",
        "type": "line",
        "expressions": [
          "eks_cluster_namespace_count"
        ],
        "span": 3,
        "rowSpan": 2,
        "format": "int"
      },
      {
        "id": "service_count",
        "title": "EKS Service Count",
        "type": "line",
        "expressions": [
          "eks_cluster_service_count"
        ],
        "span": 3,
        "rowSpan": 2,
        "format": "int"
      },
      {
        "id": "network_errors",
        "title": "Cluster Network Errors",
        "type": "line",
        "expressions": [
          "eks_cluster_net_rx_error",
          "eks_cluster_net_tx_error"
        ],
        "expressionLabels": [
          "rx",
          "tx"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "network_dropped",
        "title": "Cluster Network Drops",
        "type": "line",
        "expressions": [
          "eks_cluster_net_rx_dropped",
          "eks_cluster_net_tx_dropped"
        ],
        "expressionLabels": [
          "rx",
          "tx"
        ],
        "span": 6,
        "rowSpan": 2
      }
    ],
    "endpoint": [
      {
        "id": "pod_cpu",
        "title": "Pod CPU Utilization (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "eks_cluster_service_pod_cpu_utilization"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "pod_mem",
        "title": "Pod Memory Utilization (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "eks_cluster_service_pod_memory_utilization"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "pod_net_rx",
        "title": "Pod Network RX (KB/s)",
        "type": "line",
        "unit": "KB/s",
        "expressions": [
          "eks_cluster_service_pod_net_rx_bytes/1024"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "pod_net_rx_err",
        "title": "Pod RX Errors / s",
        "type": "line",
        "expressions": [
          "eks_cluster_service_pod_net_rx_error"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "pod_net_tx",
        "title": "Pod Network TX (KB/s)",
        "type": "line",
        "unit": "KB/s",
        "expressions": [
          "eks_cluster_service_pod_net_tx_bytes/1024"
        ],
        "span": 4,
        "rowSpan": 2
      },
      {
        "id": "pod_net_tx_err",
        "title": "Pod TX Errors / s",
        "type": "line",
        "expressions": [
          "eks_cluster_service_pod_net_tx_error"
        ],
        "span": 4,
        "rowSpan": 2
      }
    ],
    "instance": [
      {
        "id": "pods",
        "title": "Pod Count",
        "type": "line",
        "expressions": [
          "eks_cluster_node_pod_number"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "node_cpu",
        "title": "CPU Utilization (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "eks_cluster_node_cpu_utilization"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "node_mem",
        "title": "Memory Utilization (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "eks_cluster_node_memory_utilization"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "node_fs",
        "title": "FS Utilization (%)",
        "type": "line",
        "unit": "%",
        "expressions": [
          "eks_cluster_node_fs_utilization"
        ],
        "span": 3,
        "rowSpan": 2
      },
      {
        "id": "node_net_rx",
        "title": "Network RX (KB/s)",
        "type": "line",
        "unit": "KB/s",
        "expressions": [
          "eks_cluster_node_net_rx_bytes/1024",
          "eks_cluster_node_net_rx_error"
        ],
        "expressionLabels": [
          "bytes",
          "errors"
        ],
        "expressionAxes": [
          0,
          1
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "node_net_tx",
        "title": "Network TX (KB/s)",
        "type": "line",
        "unit": "KB/s",
        "expressions": [
          "eks_cluster_node_net_tx_bytes/1024",
          "eks_cluster_node_net_tx_error"
        ],
        "expressionLabels": [
          "bytes",
          "errors"
        ],
        "expressionAxes": [
          0,
          1
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "disk",
        "title": "Disk IO (B/s)",
        "type": "line",
        "expressions": [
          "eks_cluster_node_disk_io_read",
          "eks_cluster_node_disk_io_write"
        ],
        "expressionLabels": [
          "read",
          "write"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "pod_cpu",
        "title": "Pod CPU on Node",
        "type": "line",
        "unit": "%",
        "expressions": [
          "eks_cluster_node_pod_cpu_utilization"
        ],
        "span": 6,
        "rowSpan": 2
      },
      {
        "id": "pod_mem",
        "title": "Pod Memory on Node",
        "type": "line",
        "unit": "%",
        "expressions": [
          "eks_cluster_node_pod_memory_utilization"
        ],
        "span": 6,
        "rowSpan": 2
      }
    ]
  }
}
