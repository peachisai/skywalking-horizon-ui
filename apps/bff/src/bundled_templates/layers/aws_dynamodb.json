{
  "key": "AWS_DYNAMODB",
  "alias": "AWS DynamoDB",
  "group": "AWS",
  "color": "var(--sw-warn)",
  "documentLink": "https://skywalking.apache.org/docs/main/next/en/setup/backend/backend-aws-dynamodb-monitoring/",
  "aliases": {
    "services": "DynamoDB accounts",
    "endpoints": "Tables"
  },
  "components": {
    "service": true,
    "instances": false,
    "endpoints": true,
    "topology": false,
    "traces": false,
    "logs": false
  },
  "layer-header": {
    "orderBy": "throttled",
    "columns": [
      {
        "metric": "throttledR",
        "label": "Read Throttled",
        "mqe": "aws_dynamodb_read_throttled_requests",
        "aggregation": "sum"
      },
      {
        "metric": "throttledW",
        "label": "Write Throttled",
        "mqe": "aws_dynamodb_write_throttled_requests",
        "aggregation": "sum"
      },
      {
        "metric": "errR",
        "label": "Read Sys Err",
        "mqe": "aws_dynamodb_read_system_errors",
        "aggregation": "sum"
      },
      {
        "metric": "errW",
        "label": "Write Sys Err",
        "mqe": "aws_dynamodb_write_system_errors",
        "aggregation": "sum"
      }
    ]
  },
  "dashboards": {
