{
  "name": "@skywalking-horizon-ui/bff",
  "version": "1.0.0-dev",
  "private": true,
  "type": "module",
  "main": "dist/server.js",
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "NODE_ENV=development tsx watch --include 'src/ai/resources/**' src/server.ts",
    "build": "esbuild src/server.ts --bundle --platform=node --format=esm --target=node20 --outfile=dist/server.js --packages=external",
    "cli:hash": "tsx src/cli/hash.ts",
    "i18n:seed": "tsx src/i18n/seed.ts",
    "i18n:validate": "tsx src/i18n/validate.ts",
    "type-check": "tsc --noEmit",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "test:unit": "vitest run --root src/",
    "test:unit:watch": "vitest --root src/"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.1",
    "@fastify/multipart": "^10.0.0",
    "@fastify/static": "^9.1.1",
    "@jridgewell/trace-mapping": "^0.3.31",
    "@langchain/aws": "^1.4.2",
    "@langchain/core": "^1.2.1",
    "@langchain/langgraph": "^1.4.7",
    "@langchain/openai": "^1.5.3",
    "@skywalking-horizon-ui/api-client": "workspace:*",
    "argon2": "^0.41.1",
    "chokidar": "^4.0.1",
    "fastify": "^5.1.0",
    "ldapts": "^8.1.7",
    "pino": "^9.5.0",
    "pino-pretty": "^11.3.0",
    "stacktrace-parser": "^0.1.11",
    "yaml": "^2.6.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@eslint/js": "^9.14.0",
    "@types/node": "^22.9.0",
    "@typescript-eslint/eslint-plugin": "^8.16.0",
    "@typescript-eslint/parser": "^8.16.0",
    "esbuild": "^0.25.12",
    "eslint": "^9.14.0",
    "tsx": "^4.22.4",
    "typescript": "~5.6.3",
    "typescript-eslint": "^8.16.0",
    "vitest": "^4.1.0"
  }
}
